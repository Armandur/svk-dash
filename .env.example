# Generera med: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me

# Generera med: python3 -c "import bcrypt; print(bcrypt.hashpw(b'ditt-lösenord', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_HASH=$2b$12$...

# Publik URL (utan avslutande snedstreck)
BASE_URL=https://skarmar.svky.se

# Sökvägar (defaults fungerar med docker-compose)
DATABASE_PATH=/app/data/skarmar.db
UPLOADS_DIR=/app/data/uploads

# Cookiens namn (byt i dev om du delar domän med prod)
SESSION_COOKIE_NAME=session

# Larm-e-post när en skärm inte svarat på 15 minuter
ALERT_EMAIL=

# SMTP (Lettermint eller annan leverantör)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
